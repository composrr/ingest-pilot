{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ingest Pilot",
  "version": "0.1.19",
  "identifier": "com.ingestpilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ingest Pilot",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "resources": [
      "resources/guides/Ingest-Pilot-Quickstart.pdf",
      "resources/guides/Ingest-Pilot-User-Guide.pdf",
      "resources/guides/Ingest-Pilot-Walkthrough.mp4"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/composrr/ingest-pilot-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFQTIyMUVENjg0Q0NERDgKUldUWXpVeG83U0dpN3BGZjR4aFpWekFZV1V5UWIyQTM2QUtGNm9HdzhGNmNHTzJWV0xTVkhxMEkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
