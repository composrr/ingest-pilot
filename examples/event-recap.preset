{
  "schema_version": 1,
  "id": "example_event_recap",
  "name": "Event Recap",
  "description": "Simple event ingest with footage, audio, photos, and exports.",
  "icon": "calendar-video",
  "color": "#98d8c8",
  "variables": [
    {
      "id": "event_name",
      "name": "Event Name",
      "type": "short_text",
      "required": true,
      "default": "",
      "options": []
    },
    {
      "id": "shoot_date",
      "name": "Shoot Date",
      "type": "date",
      "required": true,
      "default": "today",
      "options": []
    }
  ],
  "root_folder_pattern": "{date}_{event_name}_Recap",
  "folder_tree": [
    {
      "id": "folder_media",
      "name_pattern": "Media",
      "is_footage_destination": false,
      "children": [
        {
          "id": "folder_footage",
          "name_pattern": "Footage",
          "is_footage_destination": true,
          "children": [],
          "template_files": [],
          "role": "footage"
        },
        {
          "id": "folder_audio",
          "name_pattern": "Audio",
          "is_footage_destination": false,
          "children": [],
          "template_files": [],
          "role": "audio"
        },
        {
          "id": "folder_photos",
          "name_pattern": "Photos",
          "is_footage_destination": false,
          "children": [],
          "template_files": [],
          "role": "photos"
        }
      ],
      "template_files": []
    },
    {
      "id": "folder_project",
      "name_pattern": "Project",
      "is_footage_destination": false,
      "children": [],
      "template_files": []
    },
    {
      "id": "folder_exports",
      "name_pattern": "Exports",
      "is_footage_destination": false,
      "children": [],
      "template_files": []
    }
  ],
  "file_rename_pattern": "{event_name}_{camera}_{clip#}",
  "clip_number_padding": 3,
  "per_folder_rename_overrides": {},
  "destinations": {
    "primary": "",
    "secondaries": []
  },
  "file_type_routing_overrides": {
    ".wav": "folder_audio",
    ".jpg": "folder_photos",
    ".jpeg": "folder_photos",
    ".png": "folder_photos"
  },
  "preserve_xml_sidecars": true,
  "created_at": "2026-04-24T00:00:00.000Z",
  "updated_at": "2026-04-24T00:00:00.000Z"
}
